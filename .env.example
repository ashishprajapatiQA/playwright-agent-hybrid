# =====================================================
# AI Provider API Keys — set ONE or BOTH
# =====================================================

# Google Gemini (cheap, free tier available)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY= your Gemini key

# Anthropic Claude (smarter, paid)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_claude_key_here

# OpenRouter (100+ models including Llama, Mistral, DeepSeek, GPT-4o — some free)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY= your openrouter keys 

# =====================================================
# Optional Settings
# =====================================================

# Cap on browser tool calls per agent run (default: 30)
# MAX_ITERATIONS=30
